{
  "name": "eslint-plugin-shadcn",
  "version": "1.1.0",
  "description": "ESLint plugin for shadcn/ui best practices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/",
    "docs/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamiya4047/eslint-plugin-shadcn.git"
  },
  "bugs": {
    "url": "https://github.com/kamiya4047/eslint-plugin-shadcn/issues"
  },
  "homepage": "https://github.com/kamiya4047/eslint-plugin-shadcn#readme",
  "license": "MIT",
  "publishConfig": {
    "provenance": true
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "shadcn",
    "shadcn-ui",
    "radix-ui",
    "base-ui",
    "accessibility",
    "a11y"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "dev": "bun --watch src/index.ts",
    "docs": "echo 'Documentation available in docs/ folder'",
    "prepublishOnly": "bun run build && bun test",
    "publish:npm": "npm publish --registry https://registry.npmjs.org",
    "publish:github": "npm publish --registry https://npm.pkg.github.com",
    "publish:all": "npm run publish:npm && npm run publish:github",
    "release": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "devDependencies": {
    "@kamiya4047/eslint-plugin-pretty-import": "^0.1.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "12.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "jiti": "^2.6.1",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "eslint": "^10.0.2"
  }
}
